// Schema único do backend. Toda mudança via `prisma migrate dev` (nunca db push
// fora de experimento local). Policies de RLS e extensões (PostGIS) vivem em
// migrações SQL customizadas. Ver PRD 8.2 §4.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime do app: conecta como papel NÃO-superusuário (RLS é aplicado).
  url      = env("DATABASE_URL")
  // Migrações (DDL, CREATE EXTENSION, policies, criação de papéis): papel
  // privilegiado. Superusuário burla RLS, por isso o runtime nunca usa este.
  directUrl = env("DIRECT_DATABASE_URL")
}

/// Vertical do estabelecimento — extensível para novos tipos. Ver PRD 2.1.
enum EstablishmentType {
  BARBERSHOP
  HAIR_SALON
  TATTOO_STUDIO
}

/// Papéis de acesso (RBAC). Ver PRD 2.2.
enum UserRole {
  SUPER_ADMIN
  TENANT_ADMIN
  PROFESSIONAL
  CUSTOMER
}

/// Ciclo de vida da assinatura do tenant. Ver PRD 2.13.
enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

/// Plano de assinatura contratado pelo dono. Preços/recursos vivem no
/// pacote compartilhado (`@repo/shared` → PLANS); aqui só a escolha. Ver PRD 2.13.
enum PlanTier {
  ESSENCIAL
  PROFISSIONAL
  STUDIO
}

/// Modelo de precificação do serviço. Ver PRD 2.1.
enum PricingType {
  FIXED // preço fixo
  STARTING_AT // "a partir de"
  QUOTE // orçamento sob consulta (tatuagem)
}

/// Estados do agendamento. Ver PRD 2.9.
enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Registro do estabelecimento (tenant). Tabela raiz do multi-tenancy.
/// Gerenciada pelo Super Admin / camada de aplicação — RLS de negócio recai
/// nas tabelas que referenciam `tenant_id`.
model Tenant {
  id                String            @id @default(uuid()) @db.Uuid
  name              String
  slug              String            @unique
  establishmentType EstablishmentType @map("establishment_type")
  status            TenantStatus      @default(TRIAL)
  // Assinatura (simulada — sem gateway de pagamento). Ver PRD 2.13.
  plan              PlanTier          @default(ESSENCIAL)
  trialEndsAt       DateTime?         @map("trial_ends_at")
  subscribedAt      DateTime?         @map("subscribed_at")
  documentId        String?           @map("document_id")
  phone             String?
  timezone          String            @default("America/Sao_Paulo")
  // Endereço (geocodificação lat/lng entra na Etapa 1.3 — descoberta pública).
  addressLine       String?           @map("address_line")
  city              String?
  state             String?
  postalCode        String?           @map("postal_code")
  latitude          Float?
  longitude         Float?
  // Config específica por vertical (extensível sem mudança de schema). Ver PRD 2.1.
  settings          Json?
  // Regras de agendamento (PRD 2.5): antecedência e granularidade dos slots.
  minAdvanceMinutes   Int             @default(60) @map("min_advance_minutes")
  maxAdvanceDays      Int             @default(60) @map("max_advance_days")
  slotIntervalMinutes Int             @default(15) @map("slot_interval_minutes")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  exampleItems     ExampleItem[]
  users            User[]
  termsAcceptances TermsAcceptance[]
  services         Service[]
  professionals    Professional[]
  appointments     Appointment[]
  reviews          Review[]

  @@map("tenants")
}

/// Categoria de serviço — GLOBAL (gerenciada pela plataforma), sem tenant.
/// Usada na home de descoberta (grade de ícones). Ver PRD 2.7.
model ServiceCategory {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  icon      String?
  sortOrder Int       @default(0) @map("sort_order")
  services  Service[]

  @@map("service_categories")
}

/// Serviço oferecido por um estabelecimento. Ver PRD 2.5.
model Service {
  id              String      @id @default(uuid()) @db.Uuid
  tenantId        String      @map("tenant_id") @db.Uuid
  categoryId      String?     @map("category_id") @db.Uuid
  name            String
  description     String?
  durationMinutes Int         @map("duration_minutes")
  priceCents      Int         @map("price_cents")
  pricingType     PricingType @default(FIXED) @map("pricing_type")
  active          Boolean     @default(true)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category      ServiceCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  professionals ServiceProfessional[]
  appointments  Appointment[]

  @@index([tenantId])
  @@map("services")
}

/// Profissional/colaborador (barbeiro, cabeleireiro, tatuador). Ver PRD 2.5/2.6.
/// `userId` liga a um login com papel PROFESSIONAL (opcional). Sem FK formal
/// para users (identidade de plataforma) — apenas referência por id.
model Professional {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  name      String
  bio       String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  services     ServiceProfessional[]
  workingHours WorkingHours[]
  timeBlocks   TimeBlock[]
  appointments Appointment[]

  @@index([tenantId])
  @@map("professionals")
}

/// Quais profissionais executam quais serviços (N:N). Ver PRD 2.5.
model ServiceProfessional {
  serviceId      String @map("service_id") @db.Uuid
  professionalId String @map("professional_id") @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid

  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@id([serviceId, professionalId])
  @@index([tenantId])
  @@index([professionalId])
  @@map("service_professionals")
}

/// Jornada de trabalho do profissional por dia da semana (0=domingo).
/// Minutos desde 00:00 no fuso do tenant. Ver PRD 2.5.
model WorkingHours {
  id             String @id @default(uuid()) @db.Uuid
  tenantId       String @map("tenant_id") @db.Uuid
  professionalId String @map("professional_id") @db.Uuid
  weekday        Int // 0-6 (domingo-sábado)
  startMinute    Int    @map("start_minute")
  endMinute      Int    @map("end_minute")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([professionalId])
  @@map("working_hours")
}

/// Bloqueio de agenda (folga, almoço, imprevisto). Ver PRD 2.5/2.6.
model TimeBlock {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  professionalId String   @map("professional_id") @db.Uuid
  startsAt       DateTime @map("starts_at")
  endsAt         DateTime @map("ends_at")
  reason         String?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([professionalId, startsAt])
  @@map("time_blocks")
}

/// Agendamento. Prevenção de overbooking por constraint de exclusão no Postgres
/// (ver migração). `customerId` referencia users por id (sem FK formal). Ver PRD 2.9.
model Appointment {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  serviceId      String            @map("service_id") @db.Uuid
  professionalId String            @map("professional_id") @db.Uuid
  customerId     String?           @map("customer_id") @db.Uuid
  customerName   String            @map("customer_name")
  customerEmail  String            @map("customer_email")
  customerPhone  String?           @map("customer_phone")
  startsAt       DateTime          @map("starts_at")
  endsAt         DateTime          @map("ends_at")
  status         AppointmentStatus @default(PENDING)
  priceCents     Int               @map("price_cents")
  notes          String?
  cancelReason   String?           @map("cancel_reason")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([professionalId, startsAt])
  @@index([customerId])
  @@map("appointments")
}

/// Registro de aceite de Termos de Uso / contrato (versão, data/hora, IP).
/// Requisito jurídico do onboarding. Ver PRD 2.13 / 3.4.
model TermsAcceptance {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  termsVersion String   @map("terms_version")
  ipAddress    String?  @map("ip_address")
  acceptedAt   DateTime @default(now()) @map("accepted_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("terms_acceptances")
}

/// Identidade de usuário (plataforma). Tabela de IDENTIDADE, não de negócio:
/// e-mail é único global e a autenticação precisa buscar por e-mail sem contexto
/// de tenant — por isso NÃO leva RLS forçado (ver ADR 0004). O escopo por tenant
/// dos usuários de staff é aplicado na camada de aplicação (filtro por tenantId).
///
/// - SUPER_ADMIN / CUSTOMER: `tenantId` nulo (identidade de plataforma).
/// - TENANT_ADMIN / PROFESSIONAL: `tenantId` = estabelecimento ao qual pertencem.
model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  passwordHash  String?   @map("password_hash") // nulo quando só login social
  name          String
  phone         String?
  role          UserRole
  tenantId      String?   @map("tenant_id") @db.Uuid
  googleId      String?   @unique @map("google_id")
  emailVerified Boolean   @default(false) @map("email_verified")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]
  termsAcceptances TermsAcceptance[]

  @@index([tenantId])
  @@map("users")
}

/// Sessão de refresh token (armazenado como hash) para permitir rotação e
/// revogação. Ver PRD 3.4 (rotação de refresh token).
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Tabela de negócio de exemplo (Fase 0). Prova o stack de isolamento:
/// coluna `tenant_id` + RLS forçado no Postgres. Substituída por entidades
/// reais (serviços, agendamentos) a partir da Etapa 1.2.
model ExampleItem {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("example_items")
}

/// Avaliação de um estabelecimento por um cliente que já foi atendido.
/// Uma por cliente/estabelecimento (upsert). RLS por tenant. Ver PRD 2.11.
model Review {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  customerId   String   @map("customer_id") @db.Uuid
  customerName String   @map("customer_name")
  rating       Int
  comment      String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerId])
  @@index([tenantId])
  @@map("reviews")
}
