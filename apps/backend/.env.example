# Copie para .env e ajuste. NUNCA commite o .env (segredos). Ver PRD 8.2 §10.
NODE_ENV=development
PORT=4000

# Postgres do docker-compose (host mapeia 5433).
# Runtime do app: papel NÃO-superusuário `app_user` (o RLS é aplicado a ele).
DATABASE_URL="postgresql://app_user:app@localhost:5433/agendamento?schema=public"
# Migrações: papel privilegiado (dono do banco). Superusuário burla RLS,
# por isso NUNCA é usado pelo runtime. Ver PRD 2.3.
DIRECT_DATABASE_URL="postgresql://agendamento:agendamento@localhost:5433/agendamento?schema=public"

# Redis do docker-compose (fila BullMQ — usado a partir da Etapa 1.4)
REDIS_URL="redis://localhost:6379"

# Origem do frontend (CORS)
WEB_ORIGIN="http://localhost:3000"

# JWT — gere segredos fortes em produção (ex.: openssl rand -base64 48)
JWT_ACCESS_SECRET="dev-access-secret-change-me-please-0001"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-please-0002"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS=7

LOG_LEVEL=info

# Observabilidade (opcional). Ver PRD 3.5.
# SENTRY_DSN=
